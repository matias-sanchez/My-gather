{{- /* variables.html.tmpl — one <details> per snapshot, each with a
       search input and a table. */ -}}
{{ define "variables" }}

{{- if .HasVariables }}
  {{- range .VariableSnapshots }}
<details id="{{.DetailsID}}" class="subview" open>
  <summary><span>{{.Title}}</span><span class="badge">{{.Badge}}</span></summary>
  <div class="body">
    {{- if .RangeNote }}
    <p class="snapshot-range-note">{{.RangeNote}}</p>
    {{- end }}
    {{- if .Entries }}
    <noscript><p class="banner">Search and filter require JavaScript. The full variable table is rendered server-side below.</p></noscript>
    <div class="search-row">
      <input type="search" class="variables-search"
             data-snapshot="{{.DetailsID}}"
             placeholder="Filter by name…" autocomplete="off" spellcheck="false">
      <div class="var-chips" role="tablist" aria-label="Variable filters">
        <button type="button" role="tab" aria-selected="false" class="var-chip"        data-filter="all"      data-snapshot="{{.DetailsID}}">All ({{.Count}})</button>
        {{- if gt .ChangedCount 0 }}
        <button type="button" role="tab" aria-selected="true"  class="var-chip chip-changed active" data-filter="changed" data-snapshot="{{.DetailsID}}">Changed ({{.ChangedCount}})</button>
        <button type="button" role="tab" aria-selected="false" class="var-chip"        data-filter="modified" data-snapshot="{{.DetailsID}}">Modified ({{.ModifiedCount}})</button>
        {{- else }}
        <button type="button" role="tab" aria-selected="true"  class="var-chip active" data-filter="modified" data-snapshot="{{.DetailsID}}">Modified ({{.ModifiedCount}})</button>
        {{- end }}
        <button type="button" role="tab" aria-selected="false" class="var-chip"        data-filter="default"  data-snapshot="{{.DetailsID}}">Default</button>
        <button type="button" role="tab" aria-selected="false" class="var-chip"        data-filter="unknown"  data-snapshot="{{.DetailsID}}">Unknown</button>
      </div>
      <span class="count">{{.Count}} variables · {{.ModifiedCount}} modified{{if gt .ChangedCount 0}} · {{.ChangedCount}} changed{{end}}</span>
    </div>
    <table class="variables-table" data-snapshot="{{.DetailsID}}">
      <thead><tr><th style="width:32px;"></th><th>Variable</th><th>Value</th><th style="width:120px;"></th></tr></thead>
      <tbody>
      {{- range .Entries }}
        <tr data-variable-name="{{.Name}}" data-status="{{.Status}}"{{if .Changed}} data-changed="true"{{end}}>
          <td class="status-dot"><span class="dot status-{{.Status}}" title="{{if eq .Status "modified"}}Non-default{{else if eq .Status "default"}}At default{{else}}Default unknown{{end}}"></span></td>
          <td class="mono">{{.Name}}</td>
          <td class="mono">{{.Value}}</td>
          <td class="status-label mono">{{if .Changed}}<span class="label-changed">changed</span>{{else if eq .Status "modified"}}modified{{else if eq .Status "default"}}default{{else}}–{{end}}</td>
        </tr>
      {{- end }}
      </tbody>
    </table>
    {{- else }}
    <p class="banner missing">Data not available — <code>-variables</code> was missing or unparseable for this snapshot.</p>
    {{- end }}
  </div>
</details>
  {{- end }}
{{- else }}
<p class="banner missing">Data not available — no <code>-variables</code> files were present in any snapshot of this collection.</p>
{{- end }}

{{ end }}
