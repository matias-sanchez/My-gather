{{- /* db.html.tmpl — Database Usage section body.
       Four subviews: InnoDB status (per-snapshot scalars), mysqladmin
       interactive deltas chart, processlist thread-state chart, and
       the aggregated missing-files banner. */ -}}
{{ define "db" }}

<details id="sub-db-innodb" class="subview" open>
  <summary><span>InnoDB status</span><span class="badge">-innodbstatus1</span></summary>
  <div class="body">
    {{- if .HasInnoDB }}
    <div class="callouts">
      {{- range .InnoDBMetrics }}
      <div class="callout{{if .Severity}} sev-{{.Severity}}{{end}}">
        <p class="k">{{.Label}}</p>
        <p class="v">{{.Worst}}</p>
        {{- if .Hint }}<p class="sub">{{.Hint}}</p>{{- end }}
        <p class="stats"><span>min {{.Min}}</span> · <span>avg {{.Avg}}</span> · <span>max {{.Max}}</span></p>
        {{- if and (eq .Key "pending_io") .PendingIO }}
        {{- with .PendingIO }}
        <div class="pio-chips" aria-label="Pending I/O breakdown summary">
          <span class="pio-chip"><span class="pio-k">reads</span><span class="pio-v">{{.PeakReads}}</span></span>
          <span class="pio-chip{{if .HasPendingWrite}} has{{end}}"><span class="pio-k">writes</span><span class="pio-v">{{.PeakWrites}}</span></span>
          <span class="pio-chip{{if .HasPendingFsync}} has{{end}}"><span class="pio-k">fsyncs</span><span class="pio-v">{{.PeakFsyncs}}</span></span>
        </div>
        <details class="pio-breakdown">
          <summary>Flushing breakdown <span class="cb-chev" aria-hidden="true">▸</span></summary>
          <div class="cb-body">
            {{- if .PeakSnapshot }}
            <p class="cb-caption">peak snapshot <code>{{.PeakSnapshot}}</code></p>
            {{- end }}
            <table class="pio-table">
              <thead><tr><th>Path</th><th class="num">peak</th><th>what it means</th></tr></thead>
              <tbody>
                <tr class="{{if .HasLRU}}row-warn{{end}}">
                  <td class="mono">LRU flush</td>
                  <td class="mono num">{{.PeakLRU}}</td>
                  <td>Buffer-pool free list exhausted — eviction path backlog.</td>
                </tr>
                <tr class="{{if .HasFlushList}}row-warn{{end}}">
                  <td class="mono">Flush list</td>
                  <td class="mono num">{{.PeakFlushList}}</td>
                  <td>Checkpoint-age pressure — redo is close to its limit.</td>
                </tr>
                <tr class="{{if .HasSinglePage}}row-crit{{end}}">
                  <td class="mono">Single page</td>
                  <td class="mono num">{{.PeakSinglePage}}</td>
                  <td>Synchronous stall — a user thread waited on a clean page.</td>
                </tr>
                <tr class="{{if .HasFsyncLog}}row-crit{{end}}">
                  <td class="mono">fsync · log</td>
                  <td class="mono num">{{.PeakFsyncLog}}</td>
                  <td>Redo fsync backlog — commits are waiting on disk.</td>
                </tr>
                <tr class="{{if .HasFsyncBP}}row-warn{{end}}">
                  <td class="mono">fsync · buffer pool</td>
                  <td class="mono num">{{.PeakFsyncBufferPool}}</td>
                  <td>Page cleaners can't keep up with the I/O layer.</td>
                </tr>
                <tr>
                  <td class="mono">Modified pages</td>
                  <td class="mono num">{{.PeakModifiedPages}}</td>
                  <td>Dirty-page backlog across buffer pool instances.</td>
                </tr>
              </tbody>
            </table>
            <p class="cb-note">
              LRU / flush-list / single-page split shows <em>which</em> flushing path is
              backed up. Single-page flushes &gt; 0 and pending log fsyncs &gt; 0 are the
              user-visible stall signals.
            </p>
          </div>
        </details>
        {{- end }}
        {{- end }}
        {{- if eq .Key "history_list" }}
        <div class="hll-sparkline" data-chart="innodb-hll" aria-label="History list length trend across snapshots"></div>
        {{- end }}
        {{- if .AHIFormula }}
        <details class="ahi-formula">
          <summary>Formula <span class="cb-chev" aria-hidden="true">▸</span></summary>
          <div class="cb-body">
            <p class="ahi-formula-line">
              <span class="ahi-name">hit ratio</span>
              <span class="ahi-eq">=</span>
              <span class="ahi-expr">hash / (hash + non-hash)</span>
            </p>
            {{- if .AHINoActivity }}
            <p class="cb-caption">No index activity in any snapshot — hit ratio undefined (0 / 0).</p>
            {{- else }}
            <p class="ahi-formula-line computed">
              <span class="ahi-name">at worst</span>
              <span class="ahi-eq">=</span>
              <span class="ahi-expr mono">{{.AHIWorstHash}} / ({{.AHIWorstHash}} + {{.AHIWorstNonHash}})</span>
              <span class="ahi-eq">=</span>
              <span class="ahi-result mono">{{.AHIWorstRatio}}%</span>
            </p>
            <p class="cb-caption">
              worst snapshot <code>{{.AHIWorstSnapshot}}</code>
              {{- if .AHIHasHashTable }} · hash table size {{.AHIHashTableSize}}{{end}}
            </p>
            <p class="cb-note">
              A high hit ratio means most index lookups are served directly
              from the adaptive hash index; a low one means InnoDB is
              falling back to B-tree traversal — consider whether AHI's
              memory is being paid for.
            </p>
            {{- end }}
          </div>
        </details>
        {{- end }}
        {{- if or .BreakdownPeak .BreakdownTotal }}
        <details class="semaphore-breakdown">
          <summary>Contention breakdown <span class="cb-chev" aria-hidden="true">▸</span></summary>
          <div class="cb-body" data-view="peak">
            {{- if .BreakdownPeak }}
            <div class="cb-toggle" role="tablist" aria-label="Breakdown scope">
              <button type="button" role="tab" aria-selected="true"  class="cb-tab active" data-view="peak">At peak</button>
              {{- if .BreakdownTotal }}
              <button type="button" role="tab" aria-selected="false" class="cb-tab" data-view="total">Over window</button>
              {{- end }}
            </div>
            <div class="cb-tabview" data-view="peak">
              <p class="cb-caption">
                snapshot <code>{{.BreakdownPeakSnapshot}}</code> · {{.BreakdownPeakTotal}} waits
              </p>
              <table class="cb-table">
                <thead><tr><th>Call site</th><th>Mutex</th><th class="num">waits</th><th class="num">%</th></tr></thead>
                <tbody>
                  {{- range $i, $row := .BreakdownPeak }}
                  <tr{{if ge $i 10}} class="cb-tail" hidden{{end}}>
                    <td class="mono">{{.File}}:{{.Line}}</td>
                    <td class="mono">{{if .MutexName}}{{.MutexName}}{{else}}–{{end}}</td>
                    <td class="mono num">{{.Count}}</td>
                    <td class="mono num">{{.Percent}}%</td>
                  </tr>
                  {{- end }}
                </tbody>
              </table>
              {{- if gt (len .BreakdownPeak) 10 }}
              <button type="button" class="cb-more" data-scope="peak">Show all ({{len .BreakdownPeak}} sites)</button>
              {{- end }}
            </div>
            {{- if .BreakdownTotal }}
            <div class="cb-tabview" data-view="total" hidden>
              <p class="cb-caption">summed across the capture window · {{.BreakdownTotalTotal}} waits</p>
              <table class="cb-table">
                <thead><tr><th>Call site</th><th>Mutex</th><th class="num">waits</th><th class="num">%</th></tr></thead>
                <tbody>
                  {{- range $i, $row := .BreakdownTotal }}
                  <tr{{if ge $i 10}} class="cb-tail" hidden{{end}}>
                    <td class="mono">{{.File}}:{{.Line}}</td>
                    <td class="mono">{{if .MutexName}}{{.MutexName}}{{else}}–{{end}}</td>
                    <td class="mono num">{{.Count}}</td>
                    <td class="mono num">{{.Percent}}%</td>
                  </tr>
                  {{- end }}
                </tbody>
              </table>
              {{- if gt (len .BreakdownTotal) 10 }}
              <button type="button" class="cb-more" data-scope="total">Show all ({{len .BreakdownTotal}} sites)</button>
              {{- end }}
            </div>
            {{- end }}
            {{- end }}
          </div>
        </details>
        {{- end }}
      </div>
      {{- end }}
    </div>
    {{- else if index .Unsupported "-innodbstatus1" }}
    <p class="banner missing">Unsupported pt-stalk version — <code>{{index .Unsupported "-innodbstatus1"}}</code> could not be parsed as a supported <code>-innodbstatus1</code> format.</p>
    {{- else }}
    <p class="banner missing">Data not available — no <code>-innodbstatus1</code> files were present in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-db-mysqladmin" class="subview" open>
  <summary><span>Status counters</span><span class="badge">-mysqladmin</span></summary>
  <div class="body" data-mysqladmin-host>
    {{- if .HasMysqladmin }}
    <div class="ma-charts-host" id="chart-mysqladmin" data-chart="mysqladmin"
         aria-label="Per-sample counter deltas from mysqladmin extended-status"></div>
    <noscript>
      <p class="banner">Charts and interactive filtering require JavaScript. Raw mysqladmin data
      for {{.MysqladminCount}} variables is embedded in the page as a JSON payload.</p>
    </noscript>
    {{- else if index .Unsupported "-mysqladmin" }}
    <p class="banner missing">Unsupported pt-stalk version — <code>{{index .Unsupported "-mysqladmin"}}</code> could not be parsed as a supported <code>-mysqladmin</code> format.</p>
    {{- else }}
    <p class="banner missing">Data not available — no <code>-mysqladmin</code> files were present in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-db-processlist" class="subview" open>
  <summary><span>Thread states</span><span class="badge">-processlist</span></summary>
  <div class="body">
    {{- if .HasProcesslist }}
    {{- with .ProcesslistSummary }}
    <div class="chart-summary">
      <span class="stat"><span class="k">peak active</span> <span class="v">{{.PeakActive}}</span> <span class="ctx">threads</span></span>
      <span class="stat"><span class="k">peak sleeping</span> <span class="v">{{.PeakSleeping}}</span> <span class="ctx">threads</span></span>
      {{- if .HasLongestAge }}
      <span class="stat"><span class="k">longest age</span> <span class="v">{{.LongestAge}}</span> <span class="ctx">s</span></span>
      {{- end }}
      {{- if .HasPeakRowsExamined }}
      <span class="stat"><span class="k">peak rows examined</span> <span class="v">{{.PeakRowsExamined}}</span></span>
      {{- end }}
      {{- if .HasPeakRowsSent }}
      <span class="stat"><span class="k">peak rows sent</span> <span class="v">{{.PeakRowsSent}}</span></span>
      {{- end }}
      {{- if .HasPeakQueryTextRows }}
      <span class="stat"><span class="k">query text rows</span> <span class="v">{{.PeakQueryTextRows}}</span></span>
      {{- end }}
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    <div class="chart" id="chart-processlist" data-chart="processlist"
         aria-label="Count of threads per state over time"></div>
    <noscript><p class="banner">Charts require JavaScript. Raw processlist data is embedded in the page.</p></noscript>
    <details class="slow-query-panel" aria-label="Slowest observed processlist queries"{{if .ProcesslistSummary.HasSlowQueries}} open{{end}}>
      <summary><span>Slowest observed queries</span><span class="badge">{{len .ProcesslistSummary.SlowQueries}} {{if eq (len .ProcesslistSummary.SlowQueries) 1}}query{{else}}queries{{end}}</span></summary>
      {{- if .ProcesslistSummary.HasSlowQueries }}
      <div class="slow-query-controls" role="search" aria-label="Slowest observed query filters">
        <label>
          <span>Query</span>
          <input type="search" class="slow-query-search" data-filter-field="query" placeholder="Search query or fingerprint" autocomplete="off">
        </label>
        <label>
          <span>User</span>
          <input type="search" class="slow-query-filter" data-filter-field="user" placeholder="Filter user" autocomplete="off">
        </label>
        <label>
          <span>DB</span>
          <input type="search" class="slow-query-filter" data-filter-field="db" placeholder="Filter db" autocomplete="off">
        </label>
        <label>
          <span>State</span>
          <input type="search" class="slow-query-filter" data-filter-field="state" placeholder="Filter state" autocomplete="off">
        </label>
        <span class="slow-query-count" aria-live="polite">{{len .ProcesslistSummary.SlowQueries}} of {{len .ProcesslistSummary.SlowQueries}} shown</span>
      </div>
      <p class="banner missing slow-query-filter-empty" data-slow-query-empty hidden>No slowest observed queries match the active filters.</p>
      <div class="slow-query-table-wrap">
        <table class="slow-query-table">
          <thead>
            <tr>
              <th scope="col">Rank</th>
              <th scope="col">Max age</th>
              <th scope="col">Seen</th>
              <th scope="col">First seen</th>
              <th scope="col">Last seen</th>
              <th scope="col">User</th>
              <th scope="col">DB</th>
              <th scope="col">State</th>
              <th scope="col">Rows examined</th>
              <th scope="col">Rows sent</th>
              <th scope="col">Fingerprint</th>
              <th scope="col">Query shape</th>
            </tr>
          </thead>
          <tbody>
            {{- range .ProcesslistSummary.SlowQueries }}
            <tr data-query-text="{{.FilterText}}" data-query-user="{{.FilterUser}}" data-query-db="{{.FilterDB}}" data-query-state="{{.FilterState}}">
              <td class="rank">{{.Rank}}</td>
              <td class="mono">{{.MaxAge}}</td>
              <td class="mono">{{.SeenSamples}}</td>
              <td class="mono">{{.FirstSeen}}</td>
              <td class="mono">{{.LastSeen}}</td>
              <td>{{.User}}</td>
              <td>{{.DB}}</td>
              <td>{{.State}}</td>
              <td class="mono">{{if .HasRowsExamined}}{{.RowsExamined}}{{else}}-{{end}}</td>
              <td class="mono">{{if .HasRowsSent}}{{.RowsSent}}{{else}}-{{end}}</td>
              <td class="mono">{{.Fingerprint}}</td>
              <td class="query-shape"><code>{{.Snippet}}</code></td>
            </tr>
            {{- end }}
          </tbody>
        </table>
      </div>
      {{- else }}
      <p class="banner missing">No active query text was observed in processlist rows.</p>
      {{- end }}
    </details>
    {{- else if index .Unsupported "-processlist" }}
    <p class="banner missing">Unsupported pt-stalk version — <code>{{index .Unsupported "-processlist"}}</code> could not be parsed as a supported <code>-processlist</code> format.</p>
    {{- else }}
    <p class="banner missing">Data not available — no <code>-processlist</code> files were present in this collection.</p>
    {{- end }}
  </div>
</details>

{{ end }}
