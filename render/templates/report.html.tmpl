{{- /* report.html.tmpl — top-level page frame.
       Determinism note: no Date/random in any template block; all
       dynamic values come from the model. */ -}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>my-gather {{.Title}}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="generator" content="my-gather {{.Version}}">
  <meta name="referrer" content="no-referrer">
  <link rel="icon" type="image/png" href="{{.LogoDataURI}}">
  <style>{{.EmbeddedCSS}}</style>
  <script type="application/json" id="report-data">{{.DataPayload}}</script>
</head>
<body>

<button class="nav-toggle" id="nav-toggle" type="button"
        aria-label="Toggle navigation drawer"
        aria-controls="nav-drawer"
        aria-expanded="false"
        title="Toggle navigation (⌘/Ctrl+.)">
  <img class="nav-toggle-logo" src="{{.LogoDataURI}}" alt="My-gather — Contents">
  <span class="nav-toggle-ring" aria-hidden="true"></span>
</button>

<div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>

<header class="app-header">
  <h1>pt-stalk diagnostic report <span class="sub">{{.Title}}</span></h1>
  <div class="meta">
    <span><span class="k">host</span> <span class="v">{{if .Hostname}}{{.Hostname}}{{else}}<em>(unknown)</em>{{end}}</span></span>
    <span><span class="k">snapshots</span> <span class="v">{{.SnapshotCount}}</span></span>
    <span><span class="k">generated</span> <span class="v">{{.GeneratedAtDisplay}}</span></span>
    <span><span class="k">my-gather</span> <span class="v">{{.Version}}{{if .GitCommit}} · {{.GitCommit}}{{end}}</span></span>
  </div>
</header>

<div class="layout" id="app-layout">
  <nav class="index" id="nav-drawer" aria-label="Report navigation" aria-hidden="true">
    <div class="nav-header">
      <h2>Contents</h2>
    </div>
    {{- /* NavGroups is the deterministic Level-1 + nested Level-2 shape
           computed by render.go. Each group renders as a native
           <details> so its collapsed/expanded state persists via the
           same ReportID-keyed localStorage scheme as main content. */ -}}
    {{range .NavGroups}}
    <details class="nav-group" id="nav-{{.ID}}" open>
      <summary>
        {{- /* The title is itself a link to the section so Level-1
               groups with no Level-2 children (e.g. Advisor, Parser
               Diagnostics) remain navigable from the drawer. Clicks
               on this anchor don't toggle the disclosure — app.js
               stops the event from reaching <summary>. Clicks on
               other parts of the summary still toggle natively. */}}
        <a class="nav-title" href="#{{.ID}}">{{.Title}}</a>
      </summary>
      <ul>
        {{range .Children}}
        <li><a href="#{{.ID}}">{{.Title}}</a></li>
        {{end}}
      </ul>
    </details>
    {{end}}
  </nav>

  <main class="content">

    {{/* OS Usage section */}}
    <details id="sec-os" class="section">
      <summary>
        <span>OS Usage</span>
      </summary>
      <div class="body">
        {{template "os" .}}
      </div>
    </details>

    {{/* Variables section */}}
    <details id="sec-variables" class="section">
      <summary>
        <span>Variables</span>
        <span class="badge">{{.VariablesBadge}}</span>
      </summary>
      <div class="body">
        {{template "variables" .}}
      </div>
    </details>

    {{/* Database Usage section */}}
    <details id="sec-db" class="section">
      <summary>
        <span>Database Usage</span>
      </summary>
      <div class="body">
        {{template "db" .}}
      </div>
    </details>

    {{/* Advisor section — rule-based findings, rendered at the end. */}}
    <details id="sec-advisor" class="section">
      <summary>
        <span>Advisor</span>
        <span class="badge">{{.AdvisorBadge}}</span>
      </summary>
      <div class="body">
        {{template "advisor" .}}
      </div>
    </details>

  </main>
</div>

<script>{{.EmbeddedChartJS}}</script>
<script>{{.EmbeddedAppJS}}</script>

</body>
</html>
