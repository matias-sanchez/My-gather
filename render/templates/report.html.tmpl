{{- /* report.html.tmpl — top-level page frame.
       Determinism note: no Date/random in any template block; all
       dynamic values come from the model. */ -}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>my-gather {{.Title}}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="generator" content="my-gather {{.Version}}">
  <meta name="referrer" content="no-referrer">
  <link rel="icon" type="image/png" href="{{.LogoDataURI}}">
  <style>{{.EmbeddedCSS}}</style>
  <script type="application/json" id="report-data">{{.DataPayload}}</script>
</head>
<body>

<button class="nav-toggle" id="nav-toggle" type="button"
        aria-label="Toggle navigation drawer"
        aria-controls="nav-drawer"
        aria-expanded="false"
        title="Toggle navigation (⌘/Ctrl+.)">
  <img class="nav-toggle-logo" src="{{.LogoDataURI}}" alt="My-gather — Contents">
  <span class="nav-toggle-ring" aria-hidden="true"></span>
</button>

<div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>

<header class="app-header">
  <h1>pt-stalk diagnostic report <span class="sub">{{.Title}}</span></h1>
  <div class="meta">
    <span><span class="k">host</span> <span class="v">{{if .Hostname}}{{.Hostname}}{{else}}<em>(unknown)</em>{{end}}</span></span>
    <span><span class="k">snapshots</span> <span class="v">{{.SnapshotCount}}</span></span>
    <span><span class="k">generated</span> <span class="v">{{.GeneratedAtDisplay}}</span></span>
    <span><span class="k">my-gather</span> <span class="v">{{.Version}}{{if .GitCommit}} · {{.GitCommit}}{{end}}</span></span>
  </div>
  {{- /* Report-feedback control. See specs/002-report-feedback-button/.
         Static markup, deterministic across runs (Principle IV). Dialog
         markup lives at end of <body>. */}}
  <button type="button"
          class="feedback-btn"
          id="feedback-open"
          aria-haspopup="dialog"
          aria-controls="feedback-dialog"
          aria-label="Report feedback — file an idea on GitHub">
    <span class="feedback-btn-label">Report feedback</span>
  </button>
</header>

<div class="layout" id="app-layout">
  <nav class="index" id="nav-drawer" aria-label="Report navigation" aria-hidden="true">
    <div class="nav-header">
      <h2>Contents</h2>
    </div>
    {{- /* NavGroups is the deterministic Level-1 + nested Level-2 shape
           computed by render.go. Each group renders as a native
           <details> so its collapsed/expanded state persists via the
           same ReportID-keyed localStorage scheme as main content. */ -}}
    {{range .NavGroups}}
    <details class="nav-group" id="nav-{{.ID}}" open>
      <summary>
        {{- /* The title is itself a link to the section so Level-1
               groups with no Level-2 children (e.g. Advisor, Parser
               Diagnostics) remain navigable from the drawer. Clicks
               on this anchor don't toggle the disclosure — app.js
               stops the event from reaching <summary>. Clicks on
               other parts of the summary still toggle natively. */}}
        <a class="nav-title" href="#{{.ID}}">{{.Title}}</a>
      </summary>
      <ul>
        {{range .Children}}
        <li><a href="#{{.ID}}">{{.Title}}</a></li>
        {{end}}
      </ul>
    </details>
    {{end}}
  </nav>

  <main class="content">

    {{/* Environment section — rendered first so the reader lands on
         the host / MySQL context before any time-series charts. */}}
    <details id="sec-environment" class="section">
      <summary>
        <span>Environment</span>
        {{- if .EnvBadge}}<span class="badge">{{.EnvBadge}}</span>{{end}}
      </summary>
      <div class="body">
        {{template "environment" .}}
      </div>
    </details>

    {{/* OS Usage section */}}
    <details id="sec-os" class="section">
      <summary>
        <span>OS Usage</span>
      </summary>
      <div class="body">
        {{template "os" .}}
      </div>
    </details>

    {{/* Variables section */}}
    <details id="sec-variables" class="section">
      <summary>
        <span>Variables</span>
        <span class="badge">{{.VariablesBadge}}</span>
      </summary>
      <div class="body">
        {{template "variables" .}}
      </div>
    </details>

    {{/* Database Usage section */}}
    <details id="sec-db" class="section">
      <summary>
        <span>Database Usage</span>
      </summary>
      <div class="body">
        {{template "db" .}}
      </div>
    </details>

    {{/* Advisor section — rule-based findings, rendered at the end. */}}
    <details id="sec-advisor" class="section">
      <summary>
        <span>Advisor</span>
        <span class="badge">{{.AdvisorBadge}}</span>
      </summary>
      <div class="body">
        {{template "advisor" .}}
      </div>
    </details>

  </main>
</div>

{{- /* Report-feedback dialog. Placed at end of <body> so native
       showModal()'s focus trap doesn't collide with the nav drawer.
       All IDs and class names are part of the UI contract — see
       specs/002-report-feedback-button/contracts/ui.md. */}}
<dialog id="feedback-dialog"
        class="feedback-dialog"
        data-feedback-contract="{{ .Feedback.ContractJSON }}"
        aria-labelledby="feedback-title"
        aria-describedby="feedback-help">
  <form id="feedback-form" method="dialog">
    <header class="feedback-dialog-header">
      <h2 id="feedback-title">Report feedback</h2>
      <button type="button" class="feedback-close-x" id="feedback-cancel" aria-label="Close">×</button>
    </header>
    <p id="feedback-help" class="feedback-help">
      Posts a new issue to GitHub. You can paste an image and record a voice note to attach them.
    </p>

    <div class="feedback-field">
      <label for="feedback-field-author">Author <span class="feedback-field-req">required</span></label>
      <input id="feedback-field-author" name="author" type="text" autocomplete="name" placeholder="Your name" required maxlength="{{ .Feedback.AuthorMaxChars }}">
    </div>

    <div class="feedback-field">
      <label for="feedback-field-title">Title</label>
      <input id="feedback-field-title" name="title" type="text" autocomplete="off" placeholder="Short summary…" required>
    </div>

    <div class="feedback-field">
      <label for="feedback-field-body">Body</label>
      <textarea id="feedback-field-body" name="body" rows="5" placeholder="Describe the idea or issue. Markdown supported on GitHub."></textarea>
    </div>

    <div class="feedback-field feedback-field--row">
      <label for="feedback-field-category">Category <span class="feedback-field-opt">optional</span></label>
      <select id="feedback-field-category" name="category">
        <option value="">—</option>
        {{- range $i, $c := .Feedback.Categories }}
        <option value="{{ $c }}">{{ $c }}</option>
        {{- end }}
      </select>
    </div>

    <div class="feedback-attachments" id="feedback-attachments"></div>

    <p class="feedback-hint" id="feedback-hint" hidden></p>
    <p class="feedback-error" id="feedback-error" hidden></p>

    {{- /* Fallback link surface for popup-blocker / clipboard-blocked
           paths. JS fills href and unhides when needed. */}}
    <p class="feedback-fallback" id="feedback-fallback" hidden>
      <a id="feedback-fallback-link" href="#" target="_blank" rel="noopener noreferrer">Open GitHub manually</a>
    </p>

    <footer class="feedback-actions">
      <button type="button" class="feedback-record" id="feedback-record">🎙 Record voice</button>
      <span class="feedback-actions-spacer"></span>
      <button type="submit" class="feedback-submit" id="feedback-submit" disabled>Post to GitHub</button>
    </footer>
  </form>

  {{- /* Inline success state (spec 003). The form is removed from the
         layout flow via JS on 200, so this takes over the dialog. */}}
  <div class="feedback-success" id="feedback-success" hidden>
    <div class="feedback-success-icon" aria-hidden="true">✓</div>
    <h2>Feedback posted</h2>
    <p>Your issue has been created on GitHub.</p>
    <a id="feedback-success-link" class="feedback-success-link" href="#" target="_blank" rel="noopener noreferrer">View issue on GitHub</a>
    <button type="button" class="feedback-success-close" id="feedback-success-close">Close</button>
  </div>
</dialog>

<script>{{.EmbeddedChartJS}}</script>
<script>{{.EmbeddedAppJS}}</script>

</body>
</html>
