{{- /* os.html.tmpl — OS Usage section body. Three subviews. */ -}}
{{ define "os" }}

<details id="sub-os-iostat" class="subview" open>
  <summary><span>Disk utilization</span><span class="badge">-iostat</span></summary>
  <div class="body">
    {{- if .HasIostat }}
    {{- with .IostatSummary }}
    <div class="chart-summary">
      <span class="stat"><span class="k">peak %util</span> <span class="v">{{.PeakUtil}}</span> <span class="ctx">on {{.PeakDevice}}</span></span>
      <span class="stat"><span class="k">peak aqu-sz</span> <span class="v">{{.PeakAqusz}}</span> <span class="ctx">on {{.PeakAquszDevice}}</span></span>
      <span class="stat"><span class="k">devices</span> <span class="v">{{.DeviceCount}}</span></span>
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    <div class="chart" id="chart-iostat" data-chart="iostat" aria-label="Per-device iostat utilization over time"></div>
    <noscript><p class="banner">Charts require JavaScript. Raw iostat data is embedded in the page.</p></noscript>
    {{- else }}
    <p class="banner missing">Data not available — <code>-iostat</code> was missing or unparseable in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-os-top" class="subview" open>
  <summary><span>Top CPU processes</span><span class="badge">-top</span></summary>
  <div class="body">
    {{- if .HasTop }}
    {{- with .TopSummary }}
    <div class="chart-summary">
      <span class="stat"><span class="k">#1</span> <span class="v">{{.First}}</span> <span class="ctx">avg {{.FirstAvg}}%</span></span>
      {{- if .Second }}<span class="stat"><span class="k">#2</span> <span class="v">{{.Second}}</span> <span class="ctx">avg {{.SecondAvg}}%</span></span>{{- end }}
      {{- if .Third }}<span class="stat"><span class="k">#3</span> <span class="v">{{.Third}}</span> <span class="ctx">avg {{.ThirdAvg}}%</span></span>{{- end }}
      {{- if .MysqldExtra }}<span class="stat"><span class="k">mysqld</span> <span class="v">{{.MysqldExtra}}</span> <span class="ctx">avg {{.MysqldExtraAvg}}%</span></span>{{- end }}
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    <div class="chart" id="chart-top" data-chart="top" aria-label="Top 3 CPU-consuming processes over time"></div>
    <noscript><p class="banner">Charts require JavaScript. Raw top data is embedded in the page.</p></noscript>
    {{- else }}
    <p class="banner missing">Data not available — <code>-top</code> was missing or unparseable in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-os-vmstat" class="subview" open>
  <summary><span>vmstat saturation</span><span class="badge">-vmstat</span></summary>
  <div class="body">
    {{- if .HasVmstat }}
    {{- with .VmstatSummary }}
    <div class="chart-summary">
      <span class="stat"><span class="k">peak runqueue</span> <span class="v">{{.PeakRunqueue}}</span></span>
      <span class="stat"><span class="k">peak blocked</span> <span class="v">{{.PeakBlocked}}</span></span>
      <span class="stat"><span class="k">peak iowait</span> <span class="v">{{.PeakIowait}}%</span></span>
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    <div class="vmstat-tablist" role="tablist" aria-label="vmstat category">
      <button type="button" role="tab" class="vmstat-tab active" aria-selected="true"  tabindex="0"  data-vmstat-category="cpu">CPU</button>
      <button type="button" role="tab" class="vmstat-tab"        aria-selected="false" tabindex="-1" data-vmstat-category="memory">Memory</button>
      <button type="button" role="tab" class="vmstat-tab"        aria-selected="false" tabindex="-1" data-vmstat-category="io">IO</button>
      <button type="button" role="tab" class="vmstat-tab"        aria-selected="false" tabindex="-1" data-vmstat-category="procs">Procs</button>
    </div>
    <div class="chart" id="chart-vmstat" data-chart="vmstat" aria-label="System resource saturation over time"></div>
    <noscript><p class="banner">Charts require JavaScript. Raw vmstat data is embedded in the page.</p></noscript>
    {{- else }}
    <p class="banner missing">Data not available — <code>-vmstat</code> was missing or unparseable in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-os-meminfo" class="subview" open>
  <summary><span>Memory usage</span><span class="badge">-meminfo</span></summary>
  <div class="body">
    {{- if .HasMeminfo }}
    {{- with .MeminfoSummary }}
    <div class="chart-summary">
      {{- if .MinAvailable }}<span class="stat"><span class="k">min available</span> <span class="v">{{.MinAvailable}}</span> <span class="ctx">GB</span></span>{{- end }}
      {{- if .MaxAnonPages }}<span class="stat"><span class="k">peak anon</span> <span class="v">{{.MaxAnonPages}}</span> <span class="ctx">GB</span></span>{{- end }}
      {{- if .MaxDirty }}<span class="stat"><span class="k">peak dirty</span> <span class="v">{{.MaxDirty}}</span> <span class="ctx">GB</span></span>{{- end }}
      {{- if .MaxSwapUsed }}<span class="stat"><span class="k">peak swap used</span> <span class="v">{{.MaxSwapUsed}}</span> <span class="ctx">GB</span></span>{{- end }}
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    <div class="chart" id="chart-meminfo" data-chart="meminfo" aria-label="Memory usage over time"></div>
    <noscript><p class="banner">Charts require JavaScript. Raw meminfo data is embedded in the page.</p></noscript>
    {{- else }}
    <p class="banner missing">Data not available — <code>-meminfo</code> was missing or unparseable in this collection.</p>
    {{- end }}
  </div>
</details>

<details id="sub-os-network" class="subview" open>
  <summary><span>Network</span><span class="badge">-netstat</span></summary>
  <div class="body">
    {{- if .HasNetwork }}
    {{- with .NetworkSummary }}
    <div class="chart-summary">
      {{- if .PeakRetransmits }}<span class="stat"><span class="k">peak retransmits</span> <span class="v">{{.PeakRetransmits}}</span> <span class="ctx">/s</span></span>{{- end }}
      {{- if .PeakListenOverflows }}<span class="stat"><span class="k">peak listen overflows</span> <span class="v">{{.PeakListenOverflows}}</span> <span class="ctx">/s</span></span>{{- end }}
      {{- if .PeakTimeWait }}<span class="stat"><span class="k">peak TIME_WAIT</span> <span class="v">{{.PeakTimeWait}}</span> <span class="ctx">sockets</span></span>{{- end }}
      {{- if .PeakCloseWait }}<span class="stat"><span class="k">peak CLOSE_WAIT</span> <span class="v">{{.PeakCloseWait}}</span> <span class="ctx">sockets</span></span>{{- end }}
      <span class="stat"><span class="k">samples</span> <span class="v">{{.SampleCount}}</span></span>
    </div>
    {{- end }}
    {{- if .HasNetworkCounters }}
    <h4 class="subview-h">TCP / UDP rates</h4>
    <div class="chart" id="chart-network-counters" data-chart="network-counters" aria-label="TCP and UDP counter rates over time"></div>
    {{- end }}
    {{- if .HasNetworkSockets }}
    <h4 class="subview-h">Socket states</h4>
    <div class="chart" id="chart-network-sockets" data-chart="network-sockets" aria-label="Socket state counts over time"></div>
    {{- end }}
    <noscript><p class="banner">Charts require JavaScript. Raw netstat data is embedded in the page.</p></noscript>
    {{- else }}
    <p class="banner missing">Data not available — <code>-netstat</code> and <code>-netstat_s</code> were missing or unparseable in this collection.</p>
    {{- end }}
  </div>
</details>

{{ end }}
